<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>LLM Cost Tracker</title>
    <style>
      :root {
        --lct-bg: #f6f9fc;
        --lct-panel: #ffffff;
        --lct-surface: #eef2f7;
        --lct-border: #e3e8ee;
        --lct-text: #0a2540;
        --lct-muted: #697386;
        --lct-accent: #635bff;
        --lct-accent-soft: #f0edff;
        --lct-success: #0f766e;
        --lct-success-soft: #ccfbf1;
        --lct-warning: #d97706;
        --lct-warning-soft: #ffedd5;
        --lct-danger: #dc2626;
        --lct-danger-soft: #fee2e2;
        --lct-shadow: 0 1px 2px rgba(15, 23, 42, 0.06), 0 10px 24px rgba(15, 23, 42, 0.04);

        --fs-xs:   11px;
        --fs-sm:   13px;
        --fs-md:   14px;
        --fs-lg:   18px;
        --fs-xl:   22px;
        --fs-xxl:  28px;
        --fs-hero: 44px;

        --mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
      }

      body {
        margin: 0;
        background: var(--lct-bg);
        color: var(--lct-text);
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        line-height: 1.5;
      }

      .lct-shell {
        max-width: 1180px;
        margin: 0 auto;
        padding: 24px;
      }

      .lct-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 24px;
        margin-bottom: 20px;
      }

      .lct-header-copy {
        display: grid;
        gap: 6px;
      }

      .lct-overline {
        color: var(--lct-accent);
        font-size: var(--fs-xs);
        font-weight: 700;
        letter-spacing: 0.06em;
        margin: 0;
        text-transform: uppercase;
      }

      .lct-title {
        margin: 0;
        font-size: 30px;
        font-weight: 700;
        letter-spacing: -0.01em;
        line-height: 1.2;
      }

      .lct-header-subtitle {
        color: var(--lct-muted);
        font-size: var(--fs-md);
        margin: 0;
        max-width: 640px;
      }

      .lct-nav {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
      }

      .lct-nav a {
        color: var(--lct-muted);
        text-decoration: none;
        font-size: var(--fs-md);
        padding: 8px 10px;
        border-radius: 6px;
      }

      .lct-nav a:hover {
        color: var(--lct-accent);
        background: rgba(99, 91, 255, 0.06);
      }

      .lct-nav .lct-active {
        background: var(--lct-accent-soft);
        color: var(--lct-accent);
        font-weight: 700;
      }

      .lct-panel {
        background: var(--lct-panel);
        border: 1px solid var(--lct-border);
        border-radius: 8px;
        padding: 24px;
        margin-bottom: 20px;
        box-shadow: var(--lct-shadow);
      }

      .lct-panel-tight {
        padding: 18px 20px;
      }

      .lct-muted {
        color: var(--lct-muted);
      }

      .lct-code {
        background: var(--lct-surface);
        border-radius: 4px;
        padding: 2px 6px;
        font-family: var(--mono);
        font-size: 0.92em;
      }

      .lct-grid {
        display: grid;
        gap: 16px;
      }

      .lct-hero {
        display: grid;
        gap: 16px;
        grid-template-columns: minmax(0, 1.65fr) minmax(320px, 1fr);
        margin-bottom: 20px;
      }

      .lct-hero-primary {
        display: grid;
        gap: 14px;
      }

      .lct-hero-value {
        font-size: var(--fs-hero);
        font-variant-numeric: tabular-nums;
        font-weight: 750;
        letter-spacing: -0.02em;
        line-height: 1.05;
        margin: 0;
      }

      .lct-hero-subtitle {
        color: var(--lct-muted);
        font-size: var(--fs-md);
        margin: 0;
      }

      .lct-hero-side {
        align-content: start;
        display: grid;
        gap: 16px;
      }

      .lct-stat-grid {
        display: grid;
        gap: 16px;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      }

      .lct-stat-grid-spaced {
        margin-bottom: 20px;
      }

      .lct-two-col {
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      }

      .lct-stat {
        background: var(--lct-panel);
        border: 1px solid var(--lct-border);
        border-radius: 8px;
        padding: 18px;
      }

      .lct-stat-label {
        color: var(--lct-muted);
        font-size: var(--fs-xs);
        font-weight: 600;
        letter-spacing: 0.04em;
        margin: 0 0 8px;
        text-transform: uppercase;
      }

      .lct-stat-value {
        font-size: var(--fs-xxl);
        font-variant-numeric: tabular-nums;
        font-weight: 700;
        letter-spacing: -0.01em;
        margin: 0;
      }

      .lct-stat-copy {
        color: var(--lct-muted);
        font-size: var(--fs-sm);
        margin: 6px 0 0;
      }

      .lct-section-title {
        margin: 0 0 16px;
        font-size: var(--fs-lg);
        font-weight: 600;
        letter-spacing: -0.01em;
      }

      .lct-section-head {
        align-items: flex-start;
        display: flex;
        justify-content: space-between;
        gap: 16px;
        margin-bottom: 16px;
      }

      .lct-section-copy {
        color: var(--lct-muted);
        font-size: var(--fs-md);
        margin: 4px 0 0;
      }

      .lct-table {
        border-collapse: collapse;
        width: 100%;
        font-size: var(--fs-md);
      }

      .lct-num {
        font-variant-numeric: tabular-nums;
        text-align: right !important;
        white-space: nowrap;
      }

      .lct-num-muted {
        color: var(--lct-muted);
      }

      .lct-table-compact th,
      .lct-table-compact td {
        padding: 9px 8px;
      }

      .lct-stat-sub {
        color: var(--lct-muted);
        font-size: var(--fs-xs);
        margin: 4px 0 0;
      }

      .lct-delta-badge {
        align-items: center;
        border-radius: 999px;
        display: inline-flex;
        font-size: var(--fs-xs);
        font-variant-numeric: tabular-nums;
        font-weight: 700;
        gap: 4px;
        letter-spacing: 0.01em;
        line-height: 1;
        margin: 10px 0 0;
        padding: 4px 10px;
      }
      .lct-delta-badge .lct-delta-arrow { font-size: 9px; }
      .lct-delta-neutral { background: var(--lct-surface); color: var(--lct-muted); }
      .lct-delta-up      { background: var(--lct-danger-soft);  color: #991b1b; }
      .lct-delta-down    { background: var(--lct-success-soft); color: #115e59; }

      .lct-table-wrap {
        overflow-x: auto;
      }

      .lct-table th,
      .lct-table td {
        border-bottom: 1px solid var(--lct-border);
        padding: 10px 8px;
        text-align: left;
        vertical-align: middle;
      }

      .lct-table tbody tr:last-child td { border-bottom: 0; }

      .lct-table th {
        background: #f8fafc;
        color: var(--lct-muted);
        font-weight: 600;
        font-size: var(--fs-xs);
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .lct-table tbody tr:hover {
        background: #f8fafc;
      }

      .lct-table td:last-child,
      .lct-table th:last-child {
        text-align: right;
      }

      .lct-calls-table td:last-child,
      .lct-calls-table th:last-child {
        text-align: right;
      }

      .lct-bar-track {
        background: var(--lct-surface);
        border-radius: 999px;
        height: 8px;
        overflow: hidden;
        min-width: 96px;
      }

      .lct-bar-fill {
        background: var(--lct-accent);
        height: 100%;
      }

      .lct-budget {
        display: grid;
        gap: 10px;
      }
      .lct-budget-head {
        align-items: baseline;
        display: flex;
        gap: 10px;
        justify-content: space-between;
      }
      .lct-budget-spent {
        font-size: var(--fs-xl);
        font-variant-numeric: tabular-nums;
        font-weight: 700;
        letter-spacing: -0.01em;
      }
      .lct-budget-of {
        color: var(--lct-muted);
        font-size: var(--fs-sm);
        font-weight: 500;
      }
      .lct-budget-percent {
        font-size: var(--fs-md);
        font-variant-numeric: tabular-nums;
        font-weight: 700;
      }
      .lct-budget-track {
        background: var(--lct-surface);
        border: 1px solid var(--lct-border);
        border-radius: 999px;
        height: 10px;
        overflow: hidden;
      }
      .lct-budget-fill {
        background: linear-gradient(90deg, #635bff, #7a73ff);
        height: 100%;
        transition: width 0.2s ease;
      }
      .lct-budget-fill--warn { background: linear-gradient(90deg, #f59e0b, #d97706); }
      .lct-budget-fill--over { background: linear-gradient(90deg, #ef4444, #b91c1c); }
      .lct-budget-meta {
        color: var(--lct-muted);
        font-size: var(--fs-xs);
      }

      .lct-chart {
        display: block;
        height: 180px;
        width: 100%;
      }
      .lct-chart-area { fill: rgba(99, 91, 255, 0.12); }
      .lct-chart-line { fill: none; stroke: var(--lct-accent); stroke-width: 2; stroke-linejoin: round; stroke-linecap: round; }
      .lct-chart-dot  { fill: var(--lct-accent); }
      .lct-chart-grid { stroke: var(--lct-border); stroke-dasharray: 2 3; }
      .lct-chart-axis {
        fill: var(--lct-muted);
        font-family: var(--mono);
        font-size: 10px;
      }
      .lct-chart-legend {
        color: var(--lct-muted);
        display: flex;
        font-size: var(--fs-xs);
        font-variant-numeric: tabular-nums;
        justify-content: space-between;
        margin-top: 10px;
      }
      .lct-chart-empty {
        align-items: center;
        color: var(--lct-muted);
        display: flex;
        font-size: var(--fs-sm);
        height: 180px;
        justify-content: center;
      }

      .lct-tag-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 4px;
        max-width: 380px;
      }
      .lct-tag-chip {
        align-items: center;
        background: var(--lct-surface);
        border: 1px solid var(--lct-border);
        border-radius: 4px;
        color: var(--lct-text);
        display: inline-flex;
        font-family: var(--mono);
        font-size: var(--fs-xs);
        gap: 0;
        line-height: 1.4;
        padding: 2px 6px;
        text-decoration: none;
        white-space: nowrap;
      }
      .lct-tag-chip-key { color: var(--lct-muted); }
      .lct-tag-chip-eq  { color: var(--lct-muted); padding: 0 2px; }
      .lct-tag-chip-more {
        background: transparent;
        border: 1px dashed var(--lct-border);
        color: var(--lct-muted);
      }
      .lct-tag-empty {
        color: var(--lct-muted);
        font-size: var(--fs-sm);
        font-style: italic;
      }

      .lct-empty {
        padding: 32px;
        text-align: center;
      }

      .lct-state-title {
        font-size: var(--fs-xl);
        font-weight: 600;
        margin: 0 0 8px;
      }

      .lct-state-copy {
        color: var(--lct-muted);
        margin: 0 auto;
        max-width: 640px;
      }

      .lct-state-actions {
        display: flex;
        gap: 8px;
        justify-content: center;
        margin-top: 16px;
      }

      .lct-toolbar {
        position: sticky;
        top: 12px;
        z-index: 10;
      }

      .lct-toolbar-head {
        align-items: flex-start;
        display: flex;
        gap: 16px;
        justify-content: space-between;
        margin-bottom: 16px;
      }

      .lct-toolbar-actions {
        align-items: center;
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
      }

      .lct-filters {
        display: grid;
        gap: 12px;
      }

      .lct-filter-row {
        align-items: flex-end;
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
      }

      .lct-filter-row-advanced {
        border-top: 1px solid var(--lct-border);
        padding-top: 12px;
      }

      .lct-filter-advanced {
        border-top: 1px solid var(--lct-border);
        padding-top: 4px;
      }
      .lct-filter-advanced > summary {
        color: var(--lct-muted);
        cursor: pointer;
        font-size: var(--fs-sm);
        font-weight: 600;
        letter-spacing: 0.01em;
        list-style: none;
        padding: 8px 0 4px;
        user-select: none;
      }
      .lct-filter-advanced > summary::-webkit-details-marker { display: none; }
      .lct-filter-advanced > summary::before {
        content: "▸";
        display: inline-block;
        font-size: 10px;
        margin-right: 6px;
        transition: transform .15s ease;
      }
      .lct-filter-advanced[open] > summary::before { transform: rotate(90deg); }
      .lct-filter-advanced[open] > summary { color: var(--lct-text); }
      .lct-filter-advanced > .lct-filter-row { padding-top: 10px; }

      .lct-filter-actions {
        align-items: end;
        display: flex;
        flex: 0 0 auto;
        flex-wrap: wrap;
        gap: 8px;
        justify-content: flex-end;
        margin-left: auto;
      }

      .lct-field {
        display: grid;
        gap: 6px;
        min-width: 0;
      }

      .lct-field-date {
        flex: 0 1 148px;
      }

      .lct-field-short {
        flex: 0 1 168px;
      }

      .lct-field-medium {
        flex: 1 1 210px;
      }

      .lct-field-wide {
        flex: 1 1 260px;
      }

      .lct-field-compact {
        flex: 0 1 112px;
      }

      .lct-field label {
        color: var(--lct-muted);
        font-size: var(--fs-xs);
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .lct-field input,
      .lct-field select {
        border: 1px solid var(--lct-border);
        border-radius: 6px;
        color: var(--lct-text);
        font: inherit;
        padding: 8px 10px;
        background: var(--lct-panel);
        min-height: 38px;
        width: 100%;
        box-sizing: border-box;
      }

      .lct-field input::placeholder {
        color: #8792a2;
      }

      .lct-field input:focus,
      .lct-field select:focus {
        border-color: var(--lct-accent);
        box-shadow: 0 0 0 3px rgba(99, 91, 255, 0.14);
        outline: none;
      }

      .lct-button-row {
        align-items: end;
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .lct-button {
        background: var(--lct-accent);
        border: 1px solid var(--lct-accent);
        border-radius: 6px;
        color: #ffffff;
        display: inline-block;
        font: inherit;
        font-weight: 600;
        padding: 8px 12px;
        text-decoration: none;
      }

      .lct-button:hover {
        filter: brightness(0.96);
      }

      .lct-button:focus-visible,
      .lct-chip-remove:focus-visible,
      .lct-clear-link:focus-visible,
      .lct-nav a:focus-visible {
        border-radius: 6px;
        box-shadow: 0 0 0 3px rgba(99, 91, 255, 0.18);
        outline: none;
      }

      .lct-button-secondary {
        background: var(--lct-panel);
        color: var(--lct-text);
      }

      .lct-toolbar-note {
        color: var(--lct-muted);
        font-size: var(--fs-sm);
        margin: 12px 0 0;
      }

      .lct-chip-row {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 14px;
      }

      .lct-chip {
        align-items: center;
        background: var(--lct-accent-soft);
        border: 1px solid rgba(99, 91, 255, 0.12);
        border-radius: 999px;
        color: var(--lct-text);
        display: inline-flex;
        gap: 8px;
        min-height: 32px;
        padding: 0 12px;
      }

      .lct-chip-remove {
        color: rgba(10, 37, 64, 0.58);
        font-size: var(--fs-lg);
        line-height: 1;
        text-decoration: none;
      }

      .lct-chip-remove:hover,
      .lct-clear-link:hover {
        color: var(--lct-accent);
      }

      .lct-chip-label {
        color: var(--lct-accent);
        font-size: var(--fs-xs);
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .lct-clear-link {
        color: var(--lct-accent);
        font-size: var(--fs-sm);
        font-weight: 600;
        margin-left: 4px;
        text-decoration: none;
      }

      .lct-summary-row {
        align-items: center;
        color: var(--lct-muted);
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        font-size: var(--fs-sm);
        margin-top: 14px;
      }

      .lct-pagination {
        align-items: center;
        display: flex;
        justify-content: space-between;
        gap: 12px;
        margin-top: 16px;
      }

      .lct-tags {
        display: inline-block;
        max-width: 320px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .lct-nowrap {
        white-space: nowrap;
      }

      .lct-detail-grid {
        display: grid;
        gap: 16px;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      }

      .lct-dl {
        display: grid;
        gap: 12px;
        grid-template-columns: minmax(120px, 0.4fr) minmax(0, 1fr);
        margin: 0;
      }

      .lct-dl dt {
        color: var(--lct-muted);
        font-size: var(--fs-xs);
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .lct-dl dd {
        margin: 0;
      }

      .lct-pre {
        background: #0f172a;
        border-radius: 8px;
        color: #e5e7eb;
        margin: 0;
        overflow: auto;
        padding: 16px;
      }

      @media (max-width: 800px) {
        .lct-header {
          flex-direction: column;
        }

        .lct-hero,
        .lct-stat-grid,
        .lct-two-col {
          grid-template-columns: 1fr;
        }

        .lct-filters {
          gap: 12px;
        }

        .lct-filter-row {
          align-items: stretch;
          flex-direction: column;
        }

        .lct-filter-actions {
          justify-content: flex-start;
          margin-left: 0;
          width: 100%;
        }

        .lct-field-date,
        .lct-field-short,
        .lct-field-medium,
        .lct-field-wide,
        .lct-field-compact {
          flex: 1 1 auto;
          width: 100%;
        }

        .lct-toolbar {
          position: static;
        }

        .lct-pagination {
          align-items: flex-start;
          flex-direction: column;
        }

        .lct-detail-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <main class="lct-shell">
      <header class="lct-header">
        <div class="lct-header-copy">
          <h1 class="lct-title">LLM Cost Tracker</h1>
        </div>
        <nav class="lct-nav" aria-label="Dashboard">
          <%= link_to "Overview", root_path, class: ("lct-active" if request.path.delete_suffix("/") == root_path.delete_suffix("/")) %>
          <%= link_to "Models", models_path, class: ("lct-active" if request.path.start_with?(models_path)) %>
          <%= link_to "Calls", calls_path, class: ("lct-active" if request.path.start_with?(calls_path)) %>
          <%= link_to "Tags", tags_path, class: ("lct-active" if request.path.start_with?(tags_path)) %>
          <%= link_to "Data Quality", data_quality_path, class: ("lct-active" if request.path.start_with?(data_quality_path)) %>
        </nav>
      </header>

      <%= yield %>
    </main>
    <script>
      document.addEventListener("keydown", function(event) {
        if (event.key !== "/" || event.defaultPrevented || event.metaKey || event.ctrlKey || event.altKey) return;

        var target = event.target;
        if (target && (target.isContentEditable || /^(INPUT|TEXTAREA|SELECT)$/.test(target.tagName))) return;

        var input = document.querySelector("[data-lct-filter-input]");
        if (!input) return;

        event.preventDefault();
        input.focus();
        if (typeof input.select === "function") input.select();
      });
    </script>
  </body>
</html>
