      t.decimal :total_cost, precision: 20, scale: 8, null: false, default: 0

      t.timestamps
    end unless table_exists?(:llm_cost_tracker_period_totals)

    backfill_period_totals

    add_index :llm_cost_tracker_period_totals, [:period, :period_start],
