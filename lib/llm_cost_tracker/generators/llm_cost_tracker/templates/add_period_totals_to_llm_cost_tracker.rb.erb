        WHERE total_cost IS NOT NULL
        GROUP BY #{bucket_sql}
      ) aggregated
      WHERE NOT EXISTS (
        SELECT 1
        FROM llm_cost_tracker_period_totals existing
        WHERE existing.period = aggregated.period
          AND existing.period_start = aggregated.period_start
      )
